# PostgreSQL: from backend/ run `docker compose up -d`, then match user/password/db below.
AGRIO_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agrio

AGRIO_DEBUG=true
AGRIO_JWT_SECRET=
# Expo web (and other dev frontends): comma-separated origins. Required for browser CORS.
# AGRIO_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
AGRIO_GROQ_API_KEY=gsk_your_key_here
AGRIO_MQTT_BROKER_HOST=test.mosquitto.org
AGRIO_MQTT_BROKER_PORT=1883
AGRIO_MQTT_COMMAND_TOPIC=farm/irrigation_command
AGRIO_MQTT_SENSOR_TOPIC=farm/soil_moisture

# Market price prediction (livestock). Defaults are repo-relative paths.
AGRIO_MARKET_DATA_DIR=./data/market_prices/raw
AGRIO_MARKET_FORECAST_CACHE_DIR=./data/market_prices/cache
# Set true to retrain SARIMA models when the API boots (slow; usually false)
AGRIO_MARKET_RETRAIN_ON_STARTUP=false

# Produce price prediction (fruits / vegetables).
AGRIO_PRODUCE_DATA_DIR=data/produce_prices/raw
AGRIO_PRODUCE_FORECAST_CACHE_DIR=data/produce_prices/cache
AGRIO_PRODUCE_FORECAST_HORIZON=12
AGRIO_PRODUCE_RETRAIN_ON_STARTUP=false
