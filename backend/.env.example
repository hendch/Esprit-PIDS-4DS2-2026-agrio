# PostgreSQL: from backend/ run `docker compose up -d`, then match user/password/db below.
AGRIO_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agrio

AGRIO_DEBUG=true
AGRIO_JWT_SECRET=
# Expo web (and other dev frontends): comma-separated origins. Required for browser CORS.
# AGRIO_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
AGRIO_GROQ_API_KEY=gsk_your_key_here
AGRIO_MQTT_BROKER_HOST=test.mosquitto.org
AGRIO_MQTT_BROKER_PORT=1883
AGRIO_MQTT_COMMAND_TOPIC=farm/irrigation_command
AGRIO_MQTT_SENSOR_TOPIC=farm/soil_moisture
